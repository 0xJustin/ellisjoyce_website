---
import { getPhotographyGalleryData } from "../../../data/photographyGalleryData";

const photoLibrary = Array.from(
  new Map(
    getPhotographyGalleryData().photos
      .filter((photo) => typeof photo.src === "string" && photo.src.trim().length > 0)
      .map((photo) => [
        photo.src,
        {
          id: photo.id,
          src: photo.src,
          alt: photo.alt,
          tripSlug: photo.tripSlug,
          rating: photo.rating ?? 0,
          subject: photo.subject ?? "",
          location: photo.location ?? "",
        },
      ]),
  ).values(),
).sort(
  (a, b) =>
    Number(b.rating ?? 0) - Number(a.rating ?? 0) ||
    String(a.tripSlug || "").localeCompare(String(b.tripSlug || "")),
);

const seedDraft = {
  post: {
    title: "",
    slug: "",
    section: "Science + Activism",
    excerpt: "",
    publishedAt: "",
    status: "draft",
    coverImage: "",
    legacyPath: "",
    bodyHtml: `<h2>Start here</h2><p>Write in short paragraphs, keep the opening specific, and end with a concrete next thought or call to action.</p><h3>Suggested structure</h3><ul><li>Lead with the strongest claim or scene.</li><li>Add the evidence, observation, or argument.</li><li>Close with what you want readers to do next.</li></ul>`,
    sendEmailBlast: true,
  },
  email: {
    deliveryMode: "same_day",
    campaignName: "",
    audience: "Core blog subscribers",
    subject: "",
    preheader: "",
    senderName: "Justin Ellis-Joyce",
    replyTo: "justin@ellis-joyce.com",
    ctaLabel: "Read the full post",
    ctaUrl: "",
    intro: "",
    summaryBullets: "",
    footerNote: "You are receiving this because you asked for blog updates from Ellis-Joyce.",
  },
};
const serializedSeedDraft = JSON.stringify({ draft: seedDraft, photoLibrary });
void serializedSeedDraft;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Blog Admin Studio | Ellis-Joyce</title>
    <meta
      name="description"
      content="Draft blog posts in a protected editor, save local publish files, and prepare email campaign copy."
    />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/webp" href="/assets/images/branding/favicon.webp" />
    <link rel="stylesheet" href="/assets/css/site.css" />
    <style>
      .blog-admin-page-wrap {
        width: min(1380px, calc(100vw - 2rem));
      }

      .blog-admin-main {
        display: grid;
        gap: 1.25rem;
      }

      .blog-admin-hero {
        padding: clamp(1.3rem, 2vw, 2rem);
        border: 1px solid rgba(30, 36, 32, 0.12);
        border-radius: 24px;
        background:
          radial-gradient(circle at top left, rgba(220, 231, 227, 0.92), transparent 34%),
          linear-gradient(145deg, rgba(255, 255, 255, 0.95), rgba(244, 240, 231, 0.95));
      }

      .blog-admin-hero p:last-child {
        margin-bottom: 0;
      }

      .blog-admin-meta-strip {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 0.85rem;
        margin-top: 1rem;
      }

      .blog-admin-meta-card {
        padding: 0.95rem 1rem;
        border: 1px solid rgba(30, 36, 32, 0.12);
        border-radius: 16px;
        background: rgba(255, 255, 255, 0.82);
      }

      .blog-admin-meta-card strong {
        display: block;
        margin-bottom: 0.2rem;
        font: 600 0.9rem/1.2 "IBM Plex Mono", monospace;
        letter-spacing: 0.04em;
        text-transform: uppercase;
      }

      .blog-admin-shell {
        display: grid;
        gap: 1.25rem;
      }

      .blog-admin-grid {
        display: grid;
        grid-template-columns: minmax(0, 1.08fr) minmax(360px, 0.92fr);
        gap: 1.25rem;
        align-items: start;
      }

      .blog-admin-panel {
        padding: 1.15rem;
        border: 1px solid rgba(30, 36, 32, 0.12);
        border-radius: 22px;
        background: rgba(255, 255, 255, 0.9);
      }

      .blog-admin-panel > *:first-child {
        margin-top: 0;
      }

      .blog-admin-panel > *:last-child {
        margin-bottom: 0;
      }

      .blog-admin-toolbar {
        display: flex;
        flex-wrap: wrap;
        gap: 0.65rem;
        margin-bottom: 0.85rem;
      }

      .blog-admin-status-row {
        display: flex;
        flex-wrap: wrap;
        justify-content: space-between;
        gap: 0.75rem;
        margin-bottom: 1rem;
        color: var(--muted);
        font-size: 0.95rem;
      }

      .blog-admin-section + .blog-admin-section {
        margin-top: 1.2rem;
        padding-top: 1.2rem;
        border-top: 1px solid rgba(30, 36, 32, 0.1);
      }

      .blog-admin-section-head {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 0.8rem;
        margin-bottom: 0.8rem;
      }

      .blog-admin-section-head h2,
      .blog-admin-section h2,
      .blog-admin-preview-panel h2 {
        margin: 0;
        font-family: "Cormorant Garamond", serif;
        font-size: clamp(1.65rem, 2.2vw, 2rem);
      }

      .blog-admin-section-head p,
      .blog-admin-section-note,
      .blog-admin-preview-panel p {
        margin: 0;
        color: var(--muted);
      }

      .blog-admin-field-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 0.9rem;
      }

      .blog-admin-field-grid label,
      .blog-admin-long-field,
      .blog-admin-checkbox-row {
        display: grid;
        gap: 0.35rem;
      }

      .blog-admin-field-grid label span,
      .blog-admin-long-field span,
      .blog-admin-checkbox-row span,
      .blog-admin-output-shell strong {
        font: 500 0.8rem/1.2 "IBM Plex Mono", monospace;
        letter-spacing: 0.04em;
        text-transform: uppercase;
      }

      .blog-admin-field-grid input,
      .blog-admin-field-grid select,
      .blog-admin-long-field input,
      .blog-admin-long-field textarea,
      .blog-admin-body-editor,
      .blog-admin-output-shell pre,
      .blog-admin-image-search {
        width: 100%;
        border: 1px solid rgba(30, 36, 32, 0.18);
        border-radius: 14px;
        background: rgba(244, 241, 233, 0.78);
        color: var(--ink);
        font: inherit;
      }

      .blog-admin-field-grid input,
      .blog-admin-field-grid select,
      .blog-admin-long-field input {
        min-height: 48px;
        padding: 0.75rem 0.85rem;
      }

      .blog-admin-long-field textarea,
      .blog-admin-body-editor,
      .blog-admin-image-search {
        padding: 0.9rem 1rem;
        resize: vertical;
      }

      .blog-admin-editor-toolbar {
        display: flex;
        flex-wrap: wrap;
        gap: 0.55rem;
        margin-bottom: 0.8rem;
      }

      .blog-admin-tool-button {
        min-height: 38px;
        padding: 0.5rem 0.8rem;
      }

      .blog-admin-body-editor {
        min-height: 420px;
        overflow: auto;
        border-radius: 18px;
        background: rgba(255, 255, 255, 0.95);
        font-family: "Cormorant Garamond", serif;
        font-size: 1.28rem;
        line-height: 1.65;
      }

      .blog-admin-body-editor:focus {
        outline: 2px solid rgba(29, 83, 71, 0.18);
        outline-offset: 0;
      }

      .blog-admin-body-editor[contenteditable="true"]:empty::before {
        content: attr(data-placeholder);
        color: var(--muted);
      }

      .blog-admin-body-editor h1,
      .blog-admin-body-editor h2,
      .blog-admin-body-editor h3 {
        margin: 1rem 0 0.5rem;
        line-height: 1.08;
      }

      .blog-admin-body-editor h2 {
        font-size: 2rem;
      }

      .blog-admin-body-editor h3 {
        font-size: 1.5rem;
      }

      .blog-admin-body-editor p,
      .blog-admin-body-editor ul,
      .blog-admin-body-editor ol,
      .blog-admin-body-editor blockquote,
      .blog-admin-body-editor figure {
        margin: 0 0 0.95rem;
      }

      .blog-admin-body-editor blockquote {
        margin-left: 0;
        padding-left: 1rem;
        border-left: 3px solid rgba(29, 83, 71, 0.28);
        color: var(--muted);
      }

      .blog-admin-body-editor ul,
      .blog-admin-body-editor ol {
        padding-left: 1.25rem;
      }

      .blog-admin-body-editor figure {
        display: grid;
        gap: 0.45rem;
      }

      .blog-admin-body-editor img {
        display: block;
        width: min(100%, 860px);
        height: auto;
        border-radius: 16px;
      }

      .blog-admin-body-editor figcaption {
        color: var(--muted);
        font-size: 1rem;
      }

      .blog-admin-image-library {
        margin-top: 1rem;
        padding-top: 1rem;
        border-top: 1px solid rgba(30, 36, 32, 0.1);
      }

      .blog-admin-image-controls {
        display: grid;
        grid-template-columns: auto minmax(0, 1fr);
        gap: 0.75rem;
        align-items: center;
        margin: 0.8rem 0 0.65rem;
      }

      .blog-admin-upload-button {
        position: relative;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
      }

      .blog-admin-upload-button input {
        position: absolute;
        inset: 0;
        opacity: 0;
        cursor: pointer;
      }

      .blog-admin-image-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 0.8rem;
        margin-top: 0.85rem;
      }

      .blog-admin-image-card {
        overflow: hidden;
        border: 1px solid rgba(30, 36, 32, 0.12);
        border-radius: 18px;
        background: rgba(255, 255, 255, 0.92);
      }

      .blog-admin-image-card img {
        display: block;
        width: 100%;
        aspect-ratio: 1.15 / 1;
        object-fit: cover;
        background: rgba(220, 231, 227, 0.7);
      }

      .blog-admin-image-card-body {
        padding: 0.8rem;
      }

      .blog-admin-image-card-body strong {
        display: block;
        margin-bottom: 0.2rem;
        font-size: 0.98rem;
      }

      .blog-admin-image-card-body p {
        margin: 0;
        color: var(--muted);
        font-size: 0.92rem;
      }

      .blog-admin-image-card-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.45rem;
        margin-top: 0.65rem;
      }

      .blog-admin-image-card-actions .btn {
        min-height: 34px;
        padding: 0.45rem 0.7rem;
        font-size: 0.72rem;
      }

      .blog-admin-image-empty {
        padding: 1rem;
        border: 1px dashed rgba(30, 36, 32, 0.18);
        border-radius: 16px;
        color: var(--muted);
        text-align: center;
      }

      .blog-admin-inline-row {
        display: flex;
        flex-wrap: wrap;
        gap: 0.6rem;
        align-items: end;
      }

      .blog-admin-inline-row .blog-admin-grow {
        flex: 1 1 260px;
      }

      .blog-admin-checkbox-row {
        align-items: start;
      }

      .blog-admin-checkbox-control {
        display: flex;
        align-items: center;
        gap: 0.7rem;
        min-height: 48px;
        padding: 0.75rem 0.9rem;
        border: 1px solid rgba(30, 36, 32, 0.18);
        border-radius: 14px;
        background: rgba(244, 241, 233, 0.78);
      }

      .blog-admin-checkbox-control input {
        width: 18px;
        height: 18px;
        margin: 0;
      }

      .blog-admin-guide {
        margin-top: 0.8rem;
        border: 1px dashed rgba(30, 36, 32, 0.18);
        border-radius: 16px;
        padding: 0.9rem 1rem;
        background: rgba(220, 231, 227, 0.32);
      }

      .blog-admin-guide summary {
        cursor: pointer;
        font: 500 0.85rem/1.2 "IBM Plex Mono", monospace;
        letter-spacing: 0.04em;
        text-transform: uppercase;
      }

      .blog-admin-guide p,
      .blog-admin-guide code {
        font-size: 0.95rem;
      }

      .blog-admin-preview-column {
        display: grid;
        gap: 1.05rem;
      }

      .blog-admin-preview-panel {
        position: sticky;
        top: 1rem;
      }

      .blog-admin-preview-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 0.55rem;
        margin: 0.75rem 0 1rem;
      }

      .blog-admin-chip {
        display: inline-flex;
        align-items: center;
        min-height: 34px;
        padding: 0.35rem 0.7rem;
        border-radius: 999px;
        background: rgba(29, 83, 71, 0.08);
        color: #143b33;
        font: 500 0.82rem/1.1 "IBM Plex Mono", monospace;
      }

      .blog-admin-preview-article {
        overflow: hidden;
        border: 1px solid rgba(30, 36, 32, 0.12);
        border-radius: 20px;
        background: #fff;
      }

      .blog-admin-preview-cover {
        display: block;
        width: 100%;
        aspect-ratio: 16 / 8;
        object-fit: cover;
        background:
          linear-gradient(135deg, rgba(220, 231, 227, 0.9), rgba(155, 97, 62, 0.18)),
          #eef1ea;
      }

      .blog-admin-preview-content {
        padding: 1.15rem;
      }

      .blog-admin-preview-content h1 {
        margin-top: 0.2rem;
        margin-bottom: 0.55rem;
      }

      .blog-admin-preview-excerpt {
        margin: 1rem 0 1.1rem;
        padding-left: 0.95rem;
        border-left: 3px solid rgba(29, 83, 71, 0.3);
        color: var(--muted);
        font-size: 1.02rem;
      }

      .blog-admin-preview-body h1,
      .blog-admin-preview-body h2,
      .blog-admin-preview-body h3 {
        margin: 1.2rem 0 0.45rem;
        font-family: "Cormorant Garamond", serif;
        line-height: 1.08;
      }

      .blog-admin-preview-body h1 {
        font-size: 2rem;
      }

      .blog-admin-preview-body h2 {
        font-size: 1.55rem;
      }

      .blog-admin-preview-body h3 {
        font-size: 1.25rem;
      }

      .blog-admin-preview-body p,
      .blog-admin-preview-body ul,
      .blog-admin-preview-body ol,
      .blog-admin-preview-body blockquote {
        margin: 0 0 0.9rem;
      }

      .blog-admin-preview-body ul,
      .blog-admin-preview-body ol {
        padding-left: 1.2rem;
      }

      .blog-admin-preview-body blockquote {
        padding-left: 1rem;
        border-left: 3px solid rgba(29, 83, 71, 0.28);
        color: var(--muted);
      }

      .blog-admin-email-shell {
        border: 1px solid rgba(30, 36, 32, 0.12);
        border-radius: 20px;
        background: linear-gradient(180deg, rgba(244, 241, 233, 0.78), rgba(255, 255, 255, 0.98));
        padding: 1rem;
      }

      .blog-admin-email-shell p {
        margin: 0.25rem 0;
      }

      .blog-admin-email-preview {
        margin-top: 0.85rem;
        border: 1px solid rgba(30, 36, 32, 0.12);
        border-radius: 16px;
        background: #fff;
        padding: 0.85rem;
      }

      .blog-admin-email-preview table {
        width: 100%;
        border-collapse: collapse;
      }

      .blog-admin-readiness {
        display: grid;
        gap: 0.6rem;
        margin-top: 0.9rem;
      }

      .blog-admin-readiness-item {
        display: flex;
        align-items: start;
        gap: 0.8rem;
        padding: 0.8rem 0.9rem;
        border-radius: 16px;
        border: 1px solid rgba(30, 36, 32, 0.1);
        background: rgba(244, 241, 233, 0.78);
      }

      .blog-admin-readiness-item strong {
        display: block;
        margin-bottom: 0.15rem;
        font-size: 0.96rem;
      }

      .blog-admin-readiness-item.is-ready {
        border-color: rgba(29, 83, 71, 0.18);
        background: rgba(220, 231, 227, 0.48);
      }

      .blog-admin-readiness-marker {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 1.5rem;
        height: 1.5rem;
        border-radius: 999px;
        background: rgba(30, 36, 32, 0.08);
        font: 600 0.82rem/1 "IBM Plex Mono", monospace;
      }

      .blog-admin-readiness-item.is-ready .blog-admin-readiness-marker {
        background: rgba(29, 83, 71, 0.18);
        color: #143b33;
      }

      .blog-admin-output-shell {
        display: grid;
        gap: 0.8rem;
        margin-top: 0.95rem;
      }

      .blog-admin-output-shell pre {
        min-height: 170px;
        margin: 0;
        padding: 0.9rem 1rem;
        overflow: auto;
        font: 400 0.83rem/1.55 "IBM Plex Mono", monospace;
      }

      .blog-admin-footnote {
        font-size: 0.92rem;
        color: var(--muted);
      }

      @media (max-width: 1080px) {
        .blog-admin-grid {
          grid-template-columns: minmax(0, 1fr);
        }

        .blog-admin-preview-panel {
          position: static;
        }
      }

      @media (max-width: 760px) {
        .blog-admin-page-wrap {
          width: min(100vw - 1rem, 100%);
        }

        .blog-admin-meta-strip,
        .blog-admin-field-grid,
        .blog-admin-image-grid,
        .blog-admin-image-controls {
          grid-template-columns: minmax(0, 1fr);
        }

        .blog-admin-panel,
        .blog-admin-hero {
          border-radius: 18px;
          padding: 1rem;
        }
      }
    </style>
  </head>
  <body>
    <div class="page-wrap blog-admin-page-wrap">
      <header class="site-nav" data-reveal>
        <a class="wordmark-link compact" href="/" aria-label="Home">
          <img
            class="wordmark-logo"
            src="/assets/images/branding/mountaineer.webp"
            alt="Gwendolyn and Justin Ellis-Joyce"
            loading="eager"
            decoding="async"
          />
        </a>
        <nav class="nav-links" aria-label="Primary navigation">
          <a class="nav-link" href="/">Home</a>
          <a class="nav-link" href="/blog">Blog</a>
          <a class="nav-link" href="/photography">Photography</a>
        </nav>
      </header>

      <main class="blog-admin-main" data-blog-admin-root data-blog-admin-protected hidden>
        <section class="intro-panel blog-admin-hero" data-reveal>
          <p class="eyebrow">Blog Admin</p>
          <h1>Writing Studio + Local Publish Flow</h1>
          <p>
            Draft posts in the editor, preview the final article, and save a local JSON file that the
            website now reads during build. The email campaign section builds subject lines, CTA copy,
            plain text, and a reusable HTML blast for your platform of choice.
          </p>
          <div class="cta-row">
            <a class="btn secondary" href="/blog">Back to Blog</a>
          </div>
          <div class="blog-admin-meta-strip">
            <article class="blog-admin-meta-card">
              <strong>Autosave</strong>
              <span>Draft state persists in this browser, so you can write in passes without losing your place.</span>
            </article>
            <article class="blog-admin-meta-card">
              <strong>Publish Path</strong>
              <span>Save the local post file into `src/data/localBlogEntries/&lt;slug&gt;.json`, then rebuild the site.</span>
            </article>
            <article class="blog-admin-meta-card">
              <strong>Email Handoff</strong>
              <span>Generate campaign copy and HTML that stays aligned with the post title, excerpt, and URL.</span>
            </article>
          </div>
        </section>

        <section class="blog-admin-shell" data-reveal data-blog-admin-protected hidden>
          <div class="blog-admin-grid">
            <section class="blog-admin-panel">
              <div class="blog-admin-toolbar">
                <button class="btn secondary" type="button" data-blog-admin-save>Save Draft</button>
                <button class="btn primary" type="button" data-blog-admin-save-local-file>Save Local Blog File</button>
                <button class="btn secondary" type="button" data-blog-admin-autofill-email>Fill Email From Post</button>
                <button class="btn secondary" type="button" data-blog-admin-copy-email-html>Copy Email HTML</button>
                <button class="btn secondary" type="button" data-blog-admin-download-campaign>
                  Download Campaign Packet
                </button>
                <button class="btn secondary" type="button" data-blog-admin-reset>Reset Draft</button>
              </div>

              <div class="blog-admin-status-row">
                <span data-blog-admin-status>Draft loaded.</span>
                <span data-blog-admin-saved-at>Not saved yet.</span>
              </div>

              <section class="blog-admin-section">
                <div class="blog-admin-section-head">
                  <h2>Post Setup</h2>
                  <p>These fields shape the local blog JSON file that the site now reads during build.</p>
                </div>

                <div class="blog-admin-field-grid">
                  <label>
                    <span>Title</span>
                    <input type="text" placeholder="Post title" data-blog-title />
                  </label>

                  <div class="blog-admin-checkbox-row">
                    <span>Email Blast</span>
                    <label class="blog-admin-checkbox-control">
                      <input type="checkbox" data-blog-send-email />
                      <strong>Prepare an email campaign alongside this post</strong>
                    </label>
                  </div>

                  <div class="blog-admin-inline-row blog-admin-grow">
                    <label class="blog-admin-grow">
                      <span>Slug</span>
                      <input type="text" placeholder="my-new-post" data-blog-slug />
                    </label>
                    <button class="btn secondary" type="button" data-blog-admin-generate-slug>Generate</button>
                  </div>

                  <label>
                    <span>Section</span>
                    <select data-blog-section>
                      <option>Science + Activism</option>
                      <option>Monthly Updates</option>
                      <option>Research</option>
                      <option>Field Notes</option>
                      <option>Essay</option>
                    </select>
                  </label>

                  <label>
                    <span>Publish Time</span>
                    <input type="datetime-local" data-blog-published-at />
                  </label>

                  <label>
                    <span>Workflow Status</span>
                    <select data-blog-status>
                      <option value="draft">Draft</option>
                      <option value="review">Needs Review</option>
                      <option value="ready">Ready To Publish</option>
                    </select>
                  </label>

                  <label>
                    <span>Cover Image URL</span>
                    <input type="text" placeholder="https://..." data-blog-cover-image />
                  </label>

                  <label>
                    <span>Legacy Path</span>
                    <input type="text" placeholder="/ellis-joyce/old-post" data-blog-legacy-path />
                  </label>
                </div>

                <label class="blog-admin-long-field" style="margin-top: 0.9rem;">
                  <span>Excerpt</span>
                  <textarea rows="4" placeholder="One or two lines that sell the post." data-blog-excerpt></textarea>
                </label>
              </section>

              <section class="blog-admin-section">
                <div class="blog-admin-section-head">
                  <h2>Body Draft</h2>
                  <p>Write directly in the document. Use the toolbar for formatting and insert images from the library below.</p>
                </div>

                <div class="blog-admin-editor-toolbar" data-blog-editor-toolbar role="toolbar" aria-label="Body formatting tools">
                  <button class="btn secondary blog-admin-tool-button" type="button" data-editor-block="P">Body</button>
                  <button class="btn secondary blog-admin-tool-button" type="button" data-editor-block="H2">Heading</button>
                  <button class="btn secondary blog-admin-tool-button" type="button" data-editor-block="H3">Subhead</button>
                  <button class="btn secondary blog-admin-tool-button" type="button" data-editor-command="bold">Bold</button>
                  <button class="btn secondary blog-admin-tool-button" type="button" data-editor-command="italic">Italic</button>
                  <button class="btn secondary blog-admin-tool-button" type="button" data-editor-command="underline">Underline</button>
                  <button class="btn secondary blog-admin-tool-button" type="button" data-editor-command="insertUnorderedList">Bullets</button>
                  <button class="btn secondary blog-admin-tool-button" type="button" data-editor-command="insertOrderedList">Numbered</button>
                  <button class="btn secondary blog-admin-tool-button" type="button" data-editor-block="BLOCKQUOTE">Quote</button>
                  <button class="btn secondary blog-admin-tool-button" type="button" data-editor-action="link">Link</button>
                  <button class="btn secondary blog-admin-tool-button" type="button" data-editor-action="unlink">Unlink</button>
                </div>

                <div
                  class="blog-admin-body-editor"
                  contenteditable="true"
                  spellcheck="true"
                  data-blog-body-editor
                  data-placeholder="Start writing here..."
                  aria-label="Blog body editor"
                ></div>

                <details class="blog-admin-guide">
                  <summary>Formatting guide</summary>
                  <p>
                    The toolbar covers the basics: headings, bold, italic, underline, bullets, numbered lists,
                    quotes, and links. Uploaded local images are embedded directly into the saved JSON file, so keep
                    them web-sized.
                  </p>
                </details>

                <div class="blog-admin-image-library">
                  <div class="blog-admin-section-head">
                    <h2>Image Library</h2>
                    <p>Insert from your photography catalog or upload local images for this draft.</p>
                  </div>

                  <div class="blog-admin-image-controls">
                    <label class="btn secondary blog-admin-upload-button">
                      Upload Images
                      <input type="file" accept="image/*" multiple data-blog-image-upload />
                    </label>
                    <input
                      class="blog-admin-image-search"
                      type="search"
                      autocomplete="off"
                      placeholder="Search by trip, alt text, subject, or location"
                      data-blog-image-search
                    />
                  </div>

                  <p class="blog-admin-footnote" data-blog-image-count>
                    Uploading a local image embeds it into the post file so it will publish with the article.
                  </p>

                  <div class="blog-admin-image-grid" data-blog-image-library></div>
                </div>
              </section>

              <section class="blog-admin-section">
                <div class="blog-admin-section-head">
                  <h2>Email Blast</h2>
                  <p>Set the campaign details once, then reuse the generated HTML and text in your sender.</p>
                </div>

                <div class="blog-admin-field-grid">
                  <label>
                    <span>Delivery Mode</span>
                    <select data-email-delivery-mode>
                      <option value="same_day">Blast on publish day</option>
                      <option value="next_morning">Blast the next morning</option>
                      <option value="weekly_digest">Hold for weekly digest</option>
                      <option value="publish_only">Publish with no blast</option>
                    </select>
                  </label>

                  <label>
                    <span>Audience</span>
                    <input type="text" placeholder="Core blog subscribers" data-email-audience />
                  </label>

                  <label>
                    <span>Campaign Name</span>
                    <input type="text" placeholder="2026-03 field-notes-launch" data-email-campaign-name />
                  </label>

                  <label>
                    <span>Subject Line</span>
                    <input type="text" placeholder="New on the blog..." data-email-subject />
                  </label>

                  <label>
                    <span>Preheader</span>
                    <input type="text" placeholder="One sentence for the inbox preview" data-email-preheader />
                  </label>

                  <label>
                    <span>Sender Name</span>
                    <input type="text" placeholder="Justin Ellis-Joyce" data-email-sender-name />
                  </label>

                  <label>
                    <span>Reply-To</span>
                    <input type="email" placeholder="justin@ellis-joyce.com" data-email-reply-to />
                  </label>

                  <label>
                    <span>CTA Label</span>
                    <input type="text" placeholder="Read the full post" data-email-cta-label />
                  </label>

                  <label style="grid-column: 1 / -1;">
                    <span>CTA URL</span>
                    <input type="text" placeholder="https://www.ellis-joyce.com/blog/my-post" data-email-cta-url />
                  </label>
                </div>

                <label class="blog-admin-long-field" style="margin-top: 0.9rem;">
                  <span>Intro Copy</span>
                  <textarea
                    rows="4"
                    placeholder="Why this post matters, in a tighter email voice."
                    data-email-intro
                  ></textarea>
                </label>

                <label class="blog-admin-long-field" style="margin-top: 0.9rem;">
                  <span>Bullet Highlights</span>
                  <textarea
                    rows="4"
                    placeholder="One bullet per line. Good for 2-4 quick takeaways."
                    data-email-summary-bullets
                  ></textarea>
                </label>

                <label class="blog-admin-long-field" style="margin-top: 0.9rem;">
                  <span>Footer Note</span>
                  <textarea rows="3" placeholder="Optional footer or list note." data-email-footer-note></textarea>
                </label>
              </section>

              <section class="blog-admin-section">
                <div class="blog-admin-section-head">
                  <h2>Publish Handoff</h2>
                  <p>The site now reads local JSON blog entries during build, so this page can feed that path directly.</p>
                </div>
                <p class="blog-admin-section-note">
                  Click <strong>Save Local Blog File</strong>, save the file into
                  <code>src/data/localBlogEntries/&lt;slug&gt;.json</code>, then run your normal rebuild command.
                  Local files take priority over Storyblok if they share the same slug.
                </p>
                <div class="blog-admin-readiness" data-blog-admin-readiness></div>
                <p class="blog-admin-footnote">
                  This stays local-first: save the JSON file, rebuild, and the post is part of the static site output.
                </p>
              </section>
            </section>

            <aside class="blog-admin-preview-column">
              <section class="blog-admin-panel blog-admin-preview-panel">
                <p class="kicker">Live Preview</p>
                <h2>Article Preview</h2>
                <div class="blog-admin-preview-meta">
                  <span class="blog-admin-chip" data-blog-preview-status>Draft</span>
                  <span class="blog-admin-chip" data-blog-preview-word-count>0 words</span>
                  <span class="blog-admin-chip" data-blog-preview-reading-time>1 min read</span>
                </div>

                <article class="blog-admin-preview-article">
                  <img
                    class="blog-admin-preview-cover"
                    data-blog-preview-cover
                    alt="Blog cover preview"
                    hidden
                  />
                  <div class="blog-admin-preview-content">
                    <p class="kicker" data-blog-preview-section>Science + Activism</p>
                    <h1 data-blog-preview-title>Untitled post</h1>
                    <p class="blog-post-date" data-blog-preview-date>Choose a publish time</p>
                    <p class="blog-admin-preview-excerpt" data-blog-preview-excerpt>
                      Your excerpt will show here once you add one.
                    </p>
                    <div class="blog-admin-preview-body" data-blog-preview-body></div>
                  </div>
                </article>

                <div class="blog-admin-output-shell">
                  <strong>Public URL</strong>
                  <pre data-blog-preview-url>https://www.ellis-joyce.com/blog/your-slug</pre>
                  <strong>Repository Path</strong>
                  <pre data-blog-local-file-path>src/data/localBlogEntries/your-slug.json</pre>
                  <strong>Local Blog File</strong>
                  <pre data-blog-json-preview></pre>
                </div>
              </section>

              <section class="blog-admin-panel">
                <p class="kicker">Email Preview</p>
                <h2>Campaign Draft</h2>
                <div class="blog-admin-email-shell">
                  <p><strong>Audience:</strong> <span data-email-preview-audience>Core blog subscribers</span></p>
                  <p><strong>Mode:</strong> <span data-email-preview-mode>Blast on publish day</span></p>
                  <p><strong>Subject:</strong> <span data-email-preview-subject>New on the blog</span></p>
                  <p><strong>Preheader:</strong> <span data-email-preview-preheader>Short inbox preview copy.</span></p>
                  <div class="blog-admin-email-preview" data-email-preview-html></div>
                </div>

                <div class="blog-admin-output-shell">
                  <strong>Plain Text Email</strong>
                  <pre data-email-preview-text></pre>
                </div>
              </section>
            </aside>
          </div>
        </section>
      </main>
    </div>

    <script is:inline id="blog-admin-seed" type="application/json">{serializedSeedDraft}</script>
    <script is:inline src="/assets/js/site.js" defer></script>
    <script is:inline src="/assets/js/blog-admin.js?v=20260322-1" defer></script>
  </body>
</html>
